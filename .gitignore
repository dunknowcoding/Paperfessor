# Paperfessor runtime — workspace holds live paper work (memos,
# logs, runs, archived attempts). Recreated from ``src/workspace.py``
# on demand; never commit the filled state.
workspace/.cache/
workspace/shared/research_log.md
workspace/shared/code_log.md
workspace/shared/research_guide.md
workspace/shared/code_guide.md
workspace/doc_memo.md
workspace/article_memo.md
workspace/memory.sqlite3
workspace/archived/
workspace/paper/body/
workspace/paper/templates/
workspace/src/datasets/
workspace/src/papers/
workspace/src/code/
workspace/src/figures/
workspace/src/results/
workspace/src/tools/

# Local user data — keys live in the OS keychain, never on disk.
.paperfessor/
data/
*.pfdb
*.pfsec

